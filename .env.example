# Copy this file to .env.local or another ignored .env.* file.
# Do not put real passwords or API tokens in committed files.

AUTODL_HOST=connect.bjb2.seetacloud.com
AUTODL_PORT=26034
AUTODL_USER=root
AUTODL_PROJECT=/root/autodl-tmp/pdf2latex_nn

# Kaggle CLI 2.1+ can read an access token from this file path.
# The token file itself must be ignored and chmod 600.
KAGGLE_API_TOKEN=/path/to/.kaggle/access_token
KAGGLE_CONFIG_DIR=/path/to/.kaggle
